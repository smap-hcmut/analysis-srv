# analysis-srv uses YAML-based config (not env vars directly).
# Mount this ConfigMap as a file at /app/config/config.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: analysis-config
  namespace: smap
  labels:
    app.kubernetes.io/name: analysis
    app.kubernetes.io/part-of: smap
data:
  config.yaml: |
    database:
      url: "postgresql+asyncpg://CHANGE_ME:CHANGE_ME@CHANGE_ME:5432/smap"
      url_sync: "postgresql://CHANGE_ME:CHANGE_ME@CHANGE_ME:5432/smap"
      pool_size: 20
      max_overflow: 10

    logging:
      level: "INFO"
      debug: false
      json_output: true

    kafka:
      bootstrap_servers: "kafka-cluster-kafka-bootstrap.kafka.svc.cluster.local:9092"
      topics:
        - "smap.collector.output"
      group_id: "analytics-service"

    redis:
      host: "redis-client.infrastructure.svc.cluster.local"
      port: 6379
      db: 0
      password: "CHANGE_ME"
      max_connections: 50

    minio:
      endpoint: "CHANGE_ME:9000"
      access_key: "CHANGE_ME"
      secret_key: "CHANGE_ME"
      secure: false
      crawl_results_bucket: "crawl-results"

    compression:
      enabled: true
      default_level: 2
      min_size_bytes: 1024

    preprocessor:
      min_text_length: 10
      max_comments: 5

    intent_classifier:
      confidence_threshold: 0.5
      patterns_path: "config/intent_patterns.yaml"

    impact:
      weight:
        view: 0.01
        like: 1.0
        comment: 2.0
        save: 3.0
        share: 5.0
      platform:
        tiktok: 1.0
        facebook: 1.2
        youtube: 1.5
        instagram: 1.1
        unknown: 1.0
      amplifier:
        negative: 1.5
        neutral: 1.0
        positive: 1.1
      threshold:
        viral: 70.0
        kol_followers: 50000
        max_raw_score: 100000.0

    # ─── Pipeline stage toggles ────────────────────────────────────
    pipeline:
      enable_normalization: true
      enable_dedup: true
      enable_spam: true
      enable_threads: true
      enable_nlp: true
      # Enrichment stage (entity + semantic + topic analysis via ontology)
      enable_enrichment: true
      enable_review: false
      enable_reporting: false
      enable_crisis: false

    # ─── Ontology configuration ────────────────────────────────────
    # Points to the self-contained domain ontology YAML file.
    # Each domain has ONE file containing all entities, taxonomy,
    # aspects, issues, intents, topics, and source channels.
    # Format follows OntologyRegistry Pydantic model from core-analysis.
    ontology:
      domain_ontology_path: "config/ontology/vinfast_vn.yaml"

    # ─── Enrichment sub-stage toggles ──────────────────────────────
    # Fine-grained control over which enrichment sub-stages run.
    # All default to true when enrichment is enabled.
    enrichment:
      entity_enabled: true        # Entity resolution via ontology alias matching
      semantic_enabled: true      # Aspect/issue analysis via ontology seed phrases
      topic_enabled: true         # Topic classification via ontology topic seeds
      source_influence_enabled: true
      semantic_full_enabled: true  # Full semantic inference (aspect + issue + target)

    # ─── Domain registry ───────────────────────────────────────────
    domain_registry:
      domains_dir: "config/domains"
      fallback_domain: "_default"
