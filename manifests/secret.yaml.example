apiVersion: v1
kind: Secret
metadata:
  name: analysis-secrets
  namespace: smap
  labels:
    app.kubernetes.io/name: analysis
    app.kubernetes.io/part-of: smap
type: Opaque
stringData:
  # PostgreSQL Configuration
  DB_USER: "CHANGE_ME"
  DB_PASSWORD: "CHANGE_ME"

  # Redis Configuration
  REDIS_PASSWORD: "CHANGE_ME"

  # MinIO Configuration
  MINIO_ACCESS_KEY: "CHANGE_ME"
  MINIO_SECRET_KEY: "CHANGE_ME"
